{
  "name": "lydia-thrift-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "run:android": "expo run:android",
    "run:android:release": "expo run:android --variant release",
    "run:ios": "expo run:ios",
    "run:ios:release": "expo run:ios --configuration Release",
    "build:android": "expo run:android --variant release --no-bundler",
    "build:android:apk": "cd android && gradlew.bat assembleRelease",
    "build:android:bundle": "cd android && gradlew.bat bundleRelease",
    "build:production": "eas build --platform all --profile production",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
